{
  "workbench.colorTheme": "Dracula Theme",
  // Disable Copilot autocomplete globally
  "github.copilot.enable": {
    "*": false,
    "go": false
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#ffffff",
    "activityBar.background": "#ffffff",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#df9f9f",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#ffffff",
    "statusBar.background": "#fdfdfd",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#e3e3e3",
    "statusBarItem.remoteBackground": "#fdfdfd",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#fdfdfd",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#fdfdfd99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#fdfdfd"
}
