{
  "workbench.colorTheme": "Dracula Theme",
  // Disable Copilot autocomplete globally
  "github.copilot.enable": {
    "*": false,
    "go": false
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#9a3cdc",
    "activityBar.background": "#9a3cdc",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#51360f",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#9a3cdc",
    "statusBar.background": "#8023c2",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#9a3cdc",
    "statusBarItem.remoteBackground": "#8023c2",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#8023c2",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#8023c299",
